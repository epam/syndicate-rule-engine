# Event sources consumer — variables from onprem.event_sources_consumer.constants.EventConsumerEnv
# Copy to .env and adjust for your environment.

# --- SQS (long poll / visibility) ---
# Receive batch size, 1–10 (default: 10)
SRE_EVENT_CONSUMER_SQS_BATCH_SIZE=10

# Long poll WaitTimeSeconds; lower values yield faster shutdown responsiveness (default: 20)
SRE_EVENT_CONSUMER_SQS_WAIT_SECONDS=20

# Visibility timeout in seconds (default: 60)
SRE_EVENT_CONSUMER_SQS_VISIBILITY_TIMEOUT=60

# --- boto3 (SQS client) ---
# Connect and read timeouts in seconds (default: 20)
SRE_EVENT_CONSUMER_BOTO_CONNECT_TIMEOUT=20
SRE_EVENT_CONSUMER_BOTO_READ_TIMEOUT=20

# --- HTTP (health) ---
# Health server port (default: 8081)
SRE_EVENT_CONSUMER_PORT=8081

# --- worker / credentials ---
# Credentials refresh interval in seconds (default: 2700 = 45 min)
SRE_EVENT_CONSUMER_CREDENTIALS_REFRESH_INTERVAL=2700

# --- K8s watch connector (batching) ---
SRE_EVENT_CONSUMER_K8S_BATCH_MAX_SIZE=8
SRE_EVENT_CONSUMER_K8S_BATCH_WAIT_SECONDS=3

# --- Redis (K8s event dedupe); REDIS_HOST maps to REDIS_DOMAIN ---
REDIS_DOMAIN=localhost
REDIS_PORT=6379
REDIS_PASSWORD=