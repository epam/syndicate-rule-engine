# Event sources consumer
# Copy to .env and adjust as needed

# Health server port (default: 8081)
SRE_EVENT_CONSUMER_PORT=8081

# SQS receive batch size 1-10 (default: 10)
SRE_EVENT_CONSUMER_BATCH_SIZE=10

# SQS long poll WaitTimeSeconds; shorter = faster stop (default: 2)
SRE_EVENT_CONSUMER_WAIT_SECONDS=2

# SQS VisibilityTimeout in seconds (default: 60)
SRE_EVENT_CONSUMER_VISIBILITY_TIMEOUT=60

# Credentials refresh interval in seconds (default: 3600)
SRE_EVENT_CONSUMER_CREDENTIALS_REFRESH_INTERVAL=3600
